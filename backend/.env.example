# Spring
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080
SQL_INIT_MODE=always

# MySQL
MYSQL_URL=jdbc:mysql://127.0.0.1:3306/minsi?useUnicode=true&characterEncoding=utf8&serverTimezone=UTC
MYSQL_USERNAME=minsi_user
MYSQL_PASSWORD=replace-with-mysql-password

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# AI provider
AI_PROVIDER=openai
AI_API_KEY=replace-with-ai-api-key
OPENAI_API_KEY=
AI_MODEL=gpt-5.6-terra
AI_ENDPOINT=
AI_MAX_TOKENS=240
AI_REASONING_EFFORT=none
AI_CONNECT_TIMEOUT_MS=5000
AI_READ_TIMEOUT_MS=30000

# Anthropic optional provider
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_ENDPOINT=https://api.anthropic.com/v1/messages
ANTHROPIC_MAX_TOKENS=240
ANTHROPIC_CONNECT_TIMEOUT_MS=5000
ANTHROPIC_READ_TIMEOUT_MS=30000

# Voice
VOICE_TRANSCRIPTION_PROVIDER=openai
VOICE_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
VOICE_TRANSCRIPTION_ENDPOINT=https://api.openai.com/v1/audio/transcriptions
VOICE_SPEECH_PROVIDER=openai
VOICE_SPEECH_MODEL=
VOICE_SPEECH_VOICE=marin
VOICE_SPEECH_INSTRUCTIONS=replace-with-approved-non-sensitive-voice-instructions
VOICE_SPEECH_FORMAT=mp3
VOICE_SPEECH_SPEED=1.06
VOICE_SPEECH_ENDPOINT=
VOICE_SPEECH_CONNECT_TIMEOUT_MS=5000
VOICE_SPEECH_READ_TIMEOUT_MS=30000
VOICE_REALTIME_PROVIDER=openai
VOICE_REALTIME_MODEL=gpt-realtime-2.1-mini
VOICE_REALTIME_VOICE=marin
VOICE_REALTIME_REASONING_EFFORT=low
VOICE_REALTIME_SPEED=1.06
VOICE_REALTIME_CLIENT_SECRET_TTL_SECONDS=600
VOICE_REALTIME_ENDPOINT=https://api.openai.com/v1/realtime/client_secrets

# Mail
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=replace-with-smtp-username
SMTP_PASSWORD=replace-with-smtp-password
SMTP_FROM_ADDRESS=no-reply@example.com
SMTP_FROM_NAME=Minsi
SMTP_START_TLS_ENABLED=true
SMTP_SSL_ENABLED=false
SMTP_CONNECTION_TIMEOUT_MS=5000
SMTP_READ_TIMEOUT_MS=5000
SMTP_WRITE_TIMEOUT_MS=5000

# OAuth
OAUTH_CALLBACK_BASE_URL=http://localhost:8080
WECHAT_APP_ID=replace-with-wechat-app-id
WECHAT_APP_SECRET=replace-with-wechat-app-secret
QQ_CLIENT_ID=replace-with-qq-client-id
QQ_CLIENT_SECRET=replace-with-qq-client-secret

# App security
ALLOWED_ORIGINS=http://localhost:3000
COOKIE_DOMAIN=
COOKIE_SECURE=false
HASH_SALT=replace-with-long-random-hash-salt
