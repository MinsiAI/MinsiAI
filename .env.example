# Frontend runtime configuration
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8080

# Optional local development API proxy. Keep false in production.
MINSI_ENABLE_DEV_API_PROXY=false
MINSI_DEV_API_ORIGIN=http://127.0.0.1:8080

# Optional local/development Realtime proxy. Production defaults to disabled.
MINSI_ENABLE_REALTIME_PROXY=false
MINSI_OPENAI_HTTP_PROXY=
